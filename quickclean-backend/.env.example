# MongoDB Connection String Options

# Option 1: Local MongoDB (Default)
# Required if you're running MongoDB locally on your machine
DATABASE_URL="mongodb://localhost:27017/quickclean?directConnection=true"

# Option 2: MongoDB Atlas (Cloud)
# Replace <username>, <password>, and <cluster-url> with your Atlas credentials
# DATABASE_URL="mongodb+srv://<username>:<password>@<cluster-url>/quickclean?retryWrites=true&w=majority"

# JWT Configuration
JWT_SECRET="your_jwt_secret_key_here"

# Server Port Options
PORT=5000

# SMS Provider (Fast2SMS)
FAST2SMS_KEY="your_fast2sms_authorization_key_here"

# Metabase Integration
# The URL where your Metabase instance is running (e.g. http://localhost:3000)
METABASE_SITE_URL="your_metabase_site_url"
# The Secret Key found in Metabase Admin -> Settings -> Embedding -> Embedding in other applications
METABASE_SECRET_KEY="your_metabase_secret_key"
# Default dashboard ID to show in the admin panel
METABASE_DASHBOARD_ID="1"
